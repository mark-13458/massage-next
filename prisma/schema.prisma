generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  WEBSITE
  PHONE
  WHATSAPP
  WALK_IN
  SETMORE
}

enum FileKind {
  IMAGE
  DOCUMENT
}

enum ArticleSource {
  MANUAL
  AI_GENERATED
}

enum KeywordStatus {
  PENDING
  USED
  SKIPPED
}

model User {
  id                     Int           @id @default(autoincrement())
  email                  String        @unique
  passwordHash           String
  name                   String
  role                   UserRole      @default(ADMIN)
  isActive               Boolean       @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  uploadedFiles          File[]
  confirmedAppointments  Appointment[] @relation("AppointmentConfirmedBy")
  auditLogs              AuditLog[]    @relation("AuditLogChangedBy")
}

model Service {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  slug             String        @unique
  nameDe           String
  nameEn           String
  summaryDe        String?
  summaryEn        String?
  descriptionDe    String?       @db.Text
  descriptionEn    String?       @db.Text
  durationMin      Int
  price            Decimal       @db.Decimal(10, 2)
  sortOrder        Int           @default(0)
  isFeatured       Boolean       @default(false)
  isActive         Boolean       @default(true)
  coverImageId     Int?
  coverImage       File?         @relation("ServiceCoverImage", fields: [coverImageId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appointments     Appointment[]
}

model Appointment {
  id                      Int                 @id @default(autoincrement())
  uuid                    String              @unique @default(uuid())
  customerName            String
  customerEmail           String?
  customerPhone           String
  locale                  String              @default("de")
  appointmentDate         DateTime
  appointmentTime         String
  durationMin             Int
  priceSnapshot           Decimal             @db.Decimal(10, 2)
  notes                   String?             @db.Text
  internalNote            String?             @db.Text
  status                  AppointmentStatus   @default(PENDING)
  source                  AppointmentSource   @default(WEBSITE)
  confirmationToken       String?
  confirmationSent        Boolean             @default(false)
  confirmedAt             DateTime?
  cancelledAt             DateTime?
  completedAt             DateTime?
  // Phase 17 - 改约/取消安全链接
  rescheduleToken         String?             @unique
  rescheduleTokenExpires  DateTime?
  cancelToken             String?             @unique
  cancelTokenExpires      DateTime?
  // Phase 17 - 隐私同意
  privacyConsent          Boolean             @default(false)
  privacyConsentAt        DateTime?
  dataDeleteRequestedAt   DateTime?           // 数据删除请求时间
  dataDeletedAt           DateTime?           // 数据实际删除时间
  // 关联
  serviceId               Int
  service                 Service             @relation(fields: [serviceId], references: [id])
  confirmedById           Int?
  confirmedBy             User?               @relation("AppointmentConfirmedBy", fields: [confirmedById], references: [id])
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([rescheduleToken])
  @@index([cancelToken])
  @@index([dataDeleteRequestedAt])
  @@index([confirmationToken])
  @@index([status])
  @@index([appointmentDate])
  @@index([customerPhone])
  @@index([customerEmail])
}

model File {
  id               Int        @id @default(autoincrement())
  uuid             String     @unique @default(uuid())
  originalFilename String
  storedFilename   String
  filePath         String
  fileSize         Int
  mimeType         String
  kind             FileKind   @default(IMAGE)
  altText          String?
  width            Int?
  height           Int?
  isPublic         Boolean    @default(false)
  uploadedById     Int?
  uploadedBy       User?      @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  galleryImages        GalleryImage[]
  serviceCoverImages   Service[]      @relation("ServiceCoverImage")
  articleCoverImages   Article[]      @relation("ArticleCoverImage")
}

model SiteSetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BusinessHour {
  id         Int      @id @default(autoincrement())
  weekday    Int
  dayLabelDe String
  dayLabelEn String
  openTime   String?
  closeTime  String?
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([weekday])
}

model FaqItem {
  id         Int      @id @default(autoincrement())
  questionDe String
  questionEn String
  answerDe   String   @db.Text
  answerEn   String   @db.Text
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id           Int      @id @default(autoincrement())
  customerName String
  locale       String   @default("de")
  rating       Int      @default(5)
  content      String   @db.Text
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GalleryImage {
  id         Int      @id @default(autoincrement())
  titleDe    String?
  titleEn    String?
  altDe      String?
  altEn      String?
  sortOrder  Int      @default(0)
  isCover    Boolean  @default(false)
  isActive   Boolean  @default(true)
  fileId     Int
  file       File     @relation(fields: [fileId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailLog {
  id         Int      @id @default(autoincrement())
  toEmail    String
  subject    String
  template   String?
  status     String
  error      String?  @db.Text
  sentAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuditLog {
  id              Int       @id @default(autoincrement())
  action          String    // e.g., "BOOKING_CREATED", "BOOKING_CONFIRMED", "BOOKING_CANCELLED", "BOOKING_MANAGE"
  entityType      String    // e.g., "APPOINTMENT", "USER", "SETTINGS"
  entityId        Int?
  changedBy       Int?      // userId if admin action
  changedByUser   User?     @relation("AuditLogChangedBy", fields: [changedBy], references: [id])
  oldValue        Json?
  newValue        Json?
  ipAddress       String?
  userAgent       String?
  additionalInfo  Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model BookingFrequencyLimit {
  id            Int       @id @default(autoincrement())
  limitType     String    // "PHONE", "EMAIL", "IP"
  limitValue    String    // 实际的手机号、邮箱或 IP
  bookingCount  Int       @default(1)
  lastAttemptAt DateTime
  windowStart   DateTime  // 时间窗口开始
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([limitType, limitValue, windowStart])
  @@index([limitType, limitValue])
  @@index([lastAttemptAt])
}

model LoginAttempt {
  id          Int       @id @default(autoincrement())
  email       String
  success     Boolean
  ipAddress   String?
  userAgent   String?
  failureReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email, createdAt])
  @@index([success])
  @@index([ipAddress])
}

// Phase 17 - 预约管理历史记录（用于改约追踪）
model AppointmentAudit {
  id                Int         @id @default(autoincrement())
  appointmentId     Int
  appointmentUuid   String
  action            String      // "RESCHEDULED", "CANCELLED_BY_CUSTOMER", "CANCELLED_BY_ADMIN"
  oldAppointmentDate DateTime?
  oldAppointmentTime String?
  newAppointmentDate DateTime?
  newAppointmentTime String?
  reason            String?
  customerEmail     String?
  createdAt         DateTime    @default(now())

  @@index([appointmentId])
  @@index([appointmentUuid])
  @@index([createdAt])
}

// ===== Blog 文章系统 =====

model Article {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  slug              String    @unique
  // 双语内容
  titleDe           String
  titleEn           String
  summaryDe         String?   @db.Text
  summaryEn         String?   @db.Text
  contentDe         String?   @db.LongText
  contentEn         String?   @db.LongText
  // SEO 字段
  seoTitleDe        String?
  seoTitleEn        String?
  seoDescriptionDe  String?   @db.Text
  seoDescriptionEn  String?   @db.Text
  seoKeywordsDe     String?   @db.Text
  seoKeywordsEn     String?   @db.Text
  // 封面图
  coverImageId      Int?
  coverImage        File?     @relation("ArticleCoverImage", fields: [coverImageId], references: [id])
  coverImageUrl     String?   // 外部图片 URL（Pexels 等）
  // 发布控制
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  sortOrder         Int       @default(0)
  source            ArticleSource @default(MANUAL)
  // 关联
  tags              ArticleTagRelation[]
  keywordId         Int?      @unique
  keyword           KeywordPool? @relation(fields: [keywordId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@index([slug])
}

model ArticleTag {
  id        Int                  @id @default(autoincrement())
  slug      String               @unique
  nameDe    String
  nameEn    String
  articles  ArticleTagRelation[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ArticleTagRelation {
  articleId Int
  tagId     Int
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model KeywordPool {
  id        Int            @id @default(autoincrement())
  keyword   String
  locale    String         @default("de")
  status    KeywordStatus  @default(PENDING)
  usedAt    DateTime?
  article   Article?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status, locale])
}
