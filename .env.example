# ==================== APPLICATION ====================
NODE_ENV=production
APP_URL=http://localhost
APP_PORT=3002
DEFAULT_LOCALE=de
BUSINESS_NAME="Massage Studio"

# ==================== DOCKER ====================
NGINX_PORT=80

# ==================== MAILHOG (开发环境) ====================
# 本地邮件测试工具
# 访问 Web UI: http://localhost:8025
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# ==================== MYSQL ====================
MYSQL_PORT=3307
MYSQL_DATABASE=massage_app
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_ROOT_PASSWORD=rootpassword

# ==================== DATABASE ====================
# 本地开发
DATABASE_URL="mysql://appuser:apppassword@localhost:3307/massage_app"

# Docker Compose
# DATABASE_URL="mysql://appuser:apppassword@mysql:3306/massage_app"

# ==================== ADMIN SEED ====================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"

# ==================== SESSION / AUTH ====================
SESSION_SECRET="replace_with_a_long_random_secret_min_32_chars"

# ==================== MAIL (SMTP) ====================
# 开发环境（使用 Mailhog）
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER="any"
SMTP_PASSWORD="any"

# 生产环境（使用真实 SMTP）
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

SMTP_FROM="noreply@massage-studio.de"

# ==================== MEDIA / UPLOADS ====================
# 本地开发
UPLOAD_DIR="./public/uploads"

# Docker Compose
# UPLOAD_DIR="/app/public/uploads"

# ==================== FEATURES ====================
# 隐私与数据保留（天数）
BOOKING_RETENTION_DAYS=180
DATA_DELETION_GRACE_PERIOD_DAYS=30

# ==================== OPTIONAL: CAPTCHA ====================
# CF_TURNSTILE_SITE_KEY="your_site_key"
# CF_TURNSTILE_SECRET_KEY="your_secret_key"
