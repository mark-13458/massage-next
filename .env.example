# App
NODE_ENV=production
APP_URL=http://localhost
APP_PORT=3002
NGINX_PORT=80
DEFAULT_LOCALE=de

# MySQL container
MYSQL_PORT=3307
MYSQL_DATABASE=massage_app
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_ROOT_PASSWORD=rootpassword

# Database
DATABASE_URL="mysql://appuser:apppassword@mysql:3306/massage_app"

# Admin seed
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"

# Session / Auth
SESSION_SECRET="replace_with_a_long_random_secret"

# Mail
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME="user@example.com"
SMTP_PASSWORD="password"
SMTP_FROM="no-reply@example.com"

# Media
# In Docker, mount this path as a persistent volume so uploaded files survive container rebuilds.
UPLOAD_DIR="/app/public/uploads"
